{
  "name": "rssfeedreader.e2e",
  "version": "1.0.0",
  "description": "E2E tests for RSSFeedReader using Playwright",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:api": "playwright test -c api/playwright.config.ts",
    "test:api:ui": "playwright test -c api/playwright.config.ts --ui",
    "test:api:debug": "playwright test -c api/playwright.config.ts --debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@seontechnologies/playwright-utils": "^4.3.0",
    "dotenv": "^17.4.2",
    "typescript": "^5.7.0"
  }
}
