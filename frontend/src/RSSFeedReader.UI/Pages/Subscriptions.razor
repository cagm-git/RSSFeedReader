@page "/"
@using RSSFeedReader.UI.Services
@inject SubscriptionService SubscriptionService

<PageTitle>Subscriptions</PageTitle>

<div class="container mt-4">
    <h1>RSS Subscriptions</h1>

    <div class="mb-3">
        <label for="feedUrl" class="form-label">Feed URL</label>
        <input id="feedUrl" class="form-control" @bind="feedUrl" placeholder="https://example.com/feed.xml" />
    </div>

    <button class="btn btn-primary mb-3" @onclick="AddSubscription">Add Subscription</button>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }

    @if (subscriptions is null)
    {
        <p>Loading subscriptions...</p>
    }
    else if (!subscriptions.Any())
    {
        <p>No subscriptions yet. Add one above.</p>
    }
    else
    {
        <ul class="list-group">
            @foreach (var subscription in subscriptions)
            {
                <li class="list-group-item">@subscription.Url</li>
            }
        </ul>
    }
</div>

@code {
    private string feedUrl = string.Empty;
    private string? errorMessage;
    private List<Subscription>? subscriptions;

    protected override async Task OnInitializedAsync()
    {
        await LoadSubscriptionsAsync();
    }

    private async Task LoadSubscriptionsAsync()
    {
        subscriptions = await SubscriptionService.GetSubscriptionsAsync();
        errorMessage = null;
    }

    private async Task AddSubscription()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(feedUrl))
        {
            errorMessage = "Please enter a feed URL.";
            return;
        }

        if (subscriptions?.Any(s => string.Equals(s.Url.Trim(), feedUrl.Trim(), StringComparison.OrdinalIgnoreCase)) == true)
        {
            errorMessage = "This feed URL has already been added.";
            return;
        }

        var (success, error) = await SubscriptionService.AddSubscriptionAsync(feedUrl);

        if (!success)
        {
            errorMessage = error;
            return;
        }

        feedUrl = string.Empty;
        await LoadSubscriptionsAsync();
    }
}
